# Copy this file to .env and fill values.
# Never commit .env (it is gitignored).

# Required for non-placeholder mode
GROQ_API_KEY=

# Optional: increases NVD API rate limit
NVD_API_KEY=

# Local demo default is true; set false to use real feeds + Groq
WATCHTOWER_PLACEHOLDER_MODE=true

# Optional: alternate env file path (if needed)
# WATCHTOWER_ENV_FILE=.env
